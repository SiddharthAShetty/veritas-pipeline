{
  "_meta": {
    "description": "Canonical test-name dictionary. Each entry defines the canonical name Veritas uses downstream, the expected value type, canonical unit, and every known alias/variant a clinic might send. Onboarding a new clinic's naming convention = adding aliases here, no code change (NFR-2.1).",
    "matching_strategy": "1) normalize incoming test_name (lowercase, strip punctuation/whitespace, strip parenthetical method notes) 2) exact match against aliases 3) fall back to fuzzy match (token-set ratio >= fuzzy_threshold) against canonical_name + aliases 4) unresolved names are logged for manual dictionary curation, not silently dropped",
    "fuzzy_threshold": 90,
    "source": "Derived from Clinical_name_standardization.xlsx (reviewer-curated canonical mappings) plus variants observed directly in sample clinic JSON files"
  },
